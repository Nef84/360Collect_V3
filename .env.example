# ──────────────────────────────────────────────
# 360CollectPlus — Variables de entorno raíz
# Copia como .env en la raíz del proyecto
# NUNCA subas .env al repositorio
# ──────────────────────────────────────────────

POSTGRES_DB=collectplus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA
DB_PORT=55432

JWT_SECRET_KEY=GENERA_UNA_CLAVE_ALEATORIA_LARGA_AQUI
JWT_REFRESH_SECRET_KEY=GENERA_OTRA_CLAVE_ALEATORIA_DIFERENTE_AQUI
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Omnicanalidad ──────────────────────────────────────────────────────────────

# Email — Resend (GRATIS: 100/día sin tarjeta — resend.com/signup)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=cobranza@tudominio.com

# Email — SMTP fallback (Gmail: smtp.gmail.com:587 con contraseña de app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contrasena_de_app

# SMS — TextBelt (GRATIS: 1 SMS/día sin cuenta — usa key "textbelt")
# Para más volumen: textbelt.com (~$0.01/SMS)
TEXTBELT_API_KEY=textbelt

# SMS — Twilio SMS (mismo account que WhatsApp, necesita número SMS)
TWILIO_SMS_FROM=+15551234567

# CallBot — Twilio Voice (mismo account, necesita número con voz)
TWILIO_VOICE_FROM=+15551234567
# URL pública de tu backend (para pruebas locales usa ngrok: ngrok http 8000)
CALLBOT_WEBHOOK_URL=https://tu-dominio.com
