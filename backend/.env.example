# ──────────────────────────────────────────────
# 360CollectPlus — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env al repositorio
# ──────────────────────────────────────────────

# Base de datos
POSTGRES_DB=collectplus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA
DB_PORT=55432

# Backend
JWT_SECRET_KEY=GENERA_UNA_CLAVE_ALEATORIA_LARGA_AQUI
JWT_REFRESH_SECRET_KEY=GENERA_OTRA_CLAVE_ALEATORIA_DIFERENTE_AQUI
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Puertos
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Frontend (para desarrollo local sin Docker)
VITE_API_URL=http://localhost:8000
